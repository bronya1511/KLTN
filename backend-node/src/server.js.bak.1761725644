import express from "express";
import cors from "cors";
import http from "http";
import { Server } from "socket.io";
import fs from "fs";
import path from "path";
import { pathToFileURL } from "url";

const HOST = process.env.HOST || "0.0.0.0";
const PORT = Number(process.env.PORT || 8080);

const app = express();
app.use(express.json({ limit: "10mb" }));
app.use(cors());

// Healthcheck �? test nhanh
app.get("/api/health", (req, res) => {
  res.json({ ok: true, ts: Date.now() });
});

// Mount face routes n?u c�
(async () => {
  try {
    const faceRoutesPath = path.resolve("src/routes/face.routes.js");
    if (fs.existsSync(faceRoutesPath)) {
      const { default: faceRouter } = await import(pathToFileURL(faceRoutesPath).href);
      app.use("/api/face", faceRouter);
      console.log("Mounted /api/face routes");
    } else {
      console.log("Warning: src/routes/face.routes.js not found -> skip mount");
    }
  } catch (e) {
    console.error("Error mounting face routes:", e);
  }
})();

// (T�y b?n) Mount c�c router kh�c t��ng t? ? ��y�

const server = http.createServer(app);
const io = new Server(server, { cors: { origin: "*" } });

io.on("connection", (socket) => {
  console.log("Client da ket noi socket:", socket.id);
});

server.listen(PORT, HOST, () => {
  console.log(`Backend dang chay tai http://${HOST}:${PORT}`);
});

export default app;
